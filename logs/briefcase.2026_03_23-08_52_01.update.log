pyproject.toml:
# This project was generated with 0.4.1 using template: https://github.com/beeware/briefcase-template @ v0.4.1
[tool.briefcase]
project_name = "arsenal"
bundle = "com.arsenal"
version = "2.1.0"
url = "https://github.com/vshadrov/arsenal"
license.file = "LICENSE"
author = "Василий Шадров"
author_email = "shadrovv@gmail.com"

[tool.briefcase.app.arsenal]
formal_name = "Арсенал"
description = "МОДРОП Арсенал"
long_description = "Методика Арсенал для оценки динамики риска опасного поведения и совершения повторных общественно опасных деяний пациентами с психическими расстройствами, в первую очередь - проходящими принудительное лечение и госпитализированными в недобровольном порядке. Основным фокусом внимания методики является выявление мишеней для терапевтического воздействия и отслеживание динамики тех изменений, которых удалось добиться в ходе этого воздействия."
sources = [
    "src/arsenal",
]
test_sources = [
    "tests",
]
console_app = true
main_module = "arsenal.app"
main_function = "main"
formal_main = "arsenal.app:main"

requires = [
    "textual", 
]
test_requires = [
    "pytest",
]
