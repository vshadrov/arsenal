# This project was generated with 0.4.1 using template: https://github.com/beeware/briefcase-template @ v0.4.1
[tool.briefcase]
project_name = "Arsenal"
bundle = "com.shadrov"
version = "0.0.1"
url = "https://shadrov.com/arsenal"
license.file = "LICENSE"
author = "Vasily Shadrov"
author_email = "shadrovv@gmail.com"

[tool.briefcase.app.arsenal]
formal_name = "Arsenal"
description = "Methodology for assessing the dynamics of risk of dangerous behavior in mentally ill patients."
long_description = "Методика Арсенал разработана для оценки динамики риска опасного поведения и совершения повторных общественно опасных деяний пациентами с психическими расстройствами, в первую очередь - проходящими принудительное лечение и госпитализированными в недобровольном порядке. Основным фокусом внимания методики является выявление мишеней для терапевтического воздействия и отслеживание динамики тех изменений, которых удалось добиться в ходе этого воздействия."
sources = [
    "src/arsenal",
]
test_sources = [
    "tests",
]
console_app = "arsenal.app:main"

requires = [
    "textual", 
]
test_requires = [
    "pytest",
]
